modules = ["python-3.12", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "FileForge"

[[workflows.workflow]]
name = "FileForge"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./run.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "python manage.py migrate --noinput && python manage.py qcluster & exec gunicorn --bind 0.0.0.0:5000 --workers 2 fileforge.wsgi:application"]
